---
// TransitionVideo.astro
// Wrapper that imports the new rocket story architecture:
// - RocketBackground: fixed rocket rendering layer
// - TextSlidesOverlay: fixed text overlay layer
// - RocketStorySection: scroll spacer that drives progress

import RocketBackground from "./RocketBackground.astro";
import TextSlidesOverlay from "./TextSlidesOverlay.astro";
import RocketStorySection from "./RocketStorySection.astro";
---

<!-- Rocket background (fixed, behind all content, shown only during rocket section) -->
<RocketBackground />

<!-- Text overlay (fixed, above rocket, shown only during rocket section) -->
<TextSlidesOverlay />

<!-- Scroll spacer (800vh tall, drives progress) -->
<RocketStorySection />

<script>
  import { initRocketMotionController } from "../utils/rocketFrameAnimator";

  requestAnimationFrame(() => {
    initRocketMotionController();
  });

  // Re-init on resize (debounced) — a single listener here instead of inside the function
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener(
    "resize",
    () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => initRocketMotionController(), 200);
    },
    { passive: true },
  );
</script>
